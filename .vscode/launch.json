{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug",
            "cwd": "${workspaceFolder}",
            "executable": "${command:cmsis-csolution.getBinaryFile}",
            "request": "launch",
            "type": "cortex-debug",
            "runToEntryPoint": "main",
            // "runToEntryPoint": "Reset_Handler_C",
            "servertype": "jlink",
            "showDevDebugOutput": "parsed",
            "device": "${command:cmsis-csolution.getDeviceName}_${command:cmsis-csolution.getProcessorName}",
            "interface": "jtag",
            "serverArgs": [
                "-JLinkDevicesXmlPath",
                ".alif/JLinkDevices.xml"
            ],
            "preLaunchCommands": [
                "monitor speed 15000"
            ],
            "postLaunchCommands": [
                "set $sp = __Vectors[0]",
                "set $pc = __Vectors[1]",
                "set *0xe000ed08 = __Vectors"
            ],
            "rttConfig": {
                "enabled": true,
                "address": "auto",
                "decoders": [
                    {
                        "port": 0,
                        "type": "console"
                    }
                ]
            }
        },
        {
            "name": "Attach",
            "cwd": "${workspaceFolder}",
            "executable": "${command:cmsis-csolution.getBinaryFile}",
            "request": "attach",
            "type": "cortex-debug",
            "runToEntryPoint": "main",
            "servertype": "jlink",
            "showDevDebugOutput": "parsed",
            "device": "${command:cmsis-csolution.getDeviceName}_${command:cmsis-csolution.getProcessorName}",
            "interface": "jtag",
            "serverArgs": [
                "-JLinkDevicesXmlPath",
                ".alif/JLinkDevices.xml"
            ],
            "preAttachCommands": [
                "monitor speed 15000"
            ],
            "rttConfig": {
                "enabled": true,
                "address": "auto",
                "decoders": [
                    {
                        "port": 0,
                        "type": "console"
                    }
                ]
            }
        }
    ]
}
